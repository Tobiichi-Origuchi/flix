{
    "version": "2.0.7.113-2",
    "description": "Flix - 像聊天一样传文件. 跨平台文件传输工具，支持局域网内设备间快速分享文件。",
    "homepage": "https://flix.center",
    "license": "Freeware",
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\com.ifreedomer\\flix\" \"$persist_dir\\AppData\" -Migrate",
            "$currentExe = Join-Path (Split-Path $dir) 'current\\flix.exe'",
            "$lnkPath = Join-Path $env:APPDATA 'Microsoft\\Windows\\Start Menu\\Programs\\Flix.lnk'",
            "$WshShell = New-Object -ComObject WScript.Shell",
            "$shortcut = $WshShell.CreateShortcut($lnkPath)",
            "$shortcut.TargetPath = $currentExe",
            "$shortcut.WorkingDirectory = Join-Path (Split-Path $dir) 'current'",
            "$shortcut.Save()"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Item (Join-Path $env:APPDATA 'Microsoft\\Windows\\Start Menu\\Programs\\Flix.lnk') -ErrorAction SilentlyContinue",
        "Remove-Junction \"$env:APPDATA\\com.ifreedomer\\flix\"",
        "Remove-EmptyDirectory \"$env:APPDATA\\com.ifreedomer\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Tobiichi-Origuchi/flix-pkg/releases/download/windows-v2.0.7.113/Flix-Windows-2.0.7.113-portable.zip",
            "hash": "de5725ece72dade4bae9f07f49a29f8b7b6fa38b59d28724eccaa91e76d55f62"
        }
    }
}
